# LLM Provider (FREE — get key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Database (SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./cortexai.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=cortexai_docs

# Embeddings (runs locally — no API key needed!)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Settings
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVER_K=5

# Auth
JWT_SECRET=cortexai-dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=CortexAI
APP_ENV=development
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
